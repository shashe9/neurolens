# ==========================================
# Neurolens V1 - Environment Configuration
# ==========================================

# Database Configurations
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass_123
POSTGRES_DB=neurolens_db
POSTGRES_PORT=5432
# DB Host (use 'localhost' for local running, 'postgres' for docker-compose)
DATABASE_URL=postgresql://postgres:postgres_secure_pass_123@postgres:5432/neurolens_db

# Backend API Configurations
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

# Frontend Configurations
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
