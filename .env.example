# ==========================================
# Neurolens V1 - Environment Configuration
# ==========================================

# Database Configurations
# Production primary database (e.g. Supabase Postgres)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
# Local offline fallback database (uncomment to use)
# DATABASE_URL=sqlite:///./neurolens.db

# Backend API Configurations
ENVIRONMENT=production
BACKEND_PORT=8000
JWT_SECRET_KEY=dev_secret_key_for_neurolens_2026 # Replace with a strong secret in production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend CORS config (Supports JSON array or comma-separated string)
BACKEND_CORS_ORIGINS=["https://your-frontend-domain.vercel.app","http://localhost:3000"]
# OR: BACKEND_CORS_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:3000

# Public URL of the frontend
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Automatically seed the database on boot (useful for staging / demos)
SEED_ON_STARTUP=false

# Frontend Configurations
# Points to the deployed Render backend API URL
NEXT_PUBLIC_API_BASE_URL=https://your-backend-domain.onrender.com
# Local development default
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

